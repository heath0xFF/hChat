# Maintainer: Heath
pkgname=fornax
pkgver=0.1.0
pkgrel=1
pkgdesc="Lightweight desktop chat client for local LLMs"
arch=('x86_64')
url="https://github.com/heath0xFF/fornax"
license=('MIT')
depends=('gcc-libs' 'vulkan-icd-loader')
source=("$url/releases/download/v$pkgver/fornax-linux-x86_64.tar.gz")
sha256sums=('SKIP')

package() {
    install -Dm755 fornax "$pkgdir/usr/bin/fornax"
}
